<mxfile>
  <diagram name="Meeting Minutes Architecture">
    <mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0" background="#232F3E">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

