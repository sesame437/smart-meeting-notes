        <mxCell id="arrow_browser_fe" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FF9900;strokeWidth=2;fontColor=#FFFFFF;startArrow=classic;endArrow=classic;" edge="1" source="user_browser" target="fe_index" parent="1">
